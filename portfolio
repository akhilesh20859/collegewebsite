<div class="stats-row reveal">
  <div class="stat"><span class="stat-num" data-target="11">0</span><span class="stat-label">Technologies</span></div>
  <div class="stat"><span class="stat-num" data-target="30">0</span><span class="stat-label">Projects Built</span></div>
  <div class="stat"><span class="stat-num" data-target="4">0</span><span class="stat-label">Years Coding</span></div>
  <div class="stat"><span class="stat-num" data-target="15">0</span><span class="stat-label">Happy Clients</span></div>
</div>

<section id="contact">
  <div class="contact-header reveal">
    <h2>LET'S <span>BUILD</span></h2>
    <p>Ask my AI assistant about skills, projects, or availability</p>
  </div>
  <div class="ai-chat reveal reveal-d1">
    <div class="chat-header">
      <div class="chat-status"><div class="status-dot"></div>Online</div>
      <div class="chat-title">portfolio/assistant — powered by Claude AI</div>
    </div>
    <div class="chat-messages" id="chat-messages">
      <div class="message">
        <div class="msg-avatar ai">AI</div>
        <div class="msg-bubble">Hi! I'm this developer's AI assistant. They're skilled in HTML, CSS, JS, Bootstrap, C#, C, Python, PHP, MySQL, SQL Server, and jQuery. Ask me anything about their work or how to hire them!</div>
      </div>
    </div>
    <div class="quick-questions" id="quick-qs">
      <button class="quick-btn" onclick="sendQuick(this)">What backend skills do you have?</button>
      <button class="quick-btn" onclick="sendQuick(this)">Can you build .NET apps?</button>
      <button class="quick-btn" onclick="sendQuick(this)">What databases do you use?</button>
      <button class="quick-btn" onclick="sendQuick(this)">Are you available for hire?</button>
    </div>
    <div class="chat-input-area">
      <input type="text" class="chat-input" id="chat-input" placeholder="Ask about skills, projects, availability..."/>
      <button class="chat-send" id="chat-send" onclick="sendMessage()">SEND →</button>
    </div>
  </div>
</section>

<footer>
  <div class="logo">Akhilesh Kumar</div>
  <p>© 2025 — Full Stack Developer</p>
  <div class="social-links">
    <a href="#">GitHub</a><a href="#">LinkedIn</a><a href="#">Email</a>
  </div>
</footer>

<script>
// Cursor
const cursor=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
let mx=0,my=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cursor.style.left=mx+'px';cursor.style.top=my+'px';
  setTimeout(()=>{ring.style.left=mx+'px';ring.style.top=my+'px';},90);
});

// Particles
const snippets=['</div>','function()','SELECT *','#include','import','<?php','$(this)','@media','C# .NET','while(true)','async/await','NULL','int main','Bootstrap','return true','for(;;)','mysqli_query','Console.Write'];
const pc=document.getElementById('particles');
snippets.forEach(s=>{
  const p=document.createElement('div');p.className='particle';p.textContent=s;
  p.style.left=(4+Math.random()*92)+'%';p.style.bottom='-2rem';
  p.style.animationDuration=(18+Math.random()*24)+'s';
  p.style.animationDelay=(Math.random()*22)+'s';
  pc.appendChild(p);
});

// Marquee
const tech=['HTML5','★','CSS3','★','JavaScript','★','Bootstrap','★','C#','★','C','★','Python','★','PHP','★','MySQL','★','SQL Server','★','jQuery','★'];
const track=document.getElementById('marquee-track');
[...tech,...tech].forEach(t=>{
  const d=document.createElement('div');
  d.className='marquee-item'+(t==='★'?' hi':'');
  d.textContent=t;track.appendChild(d);
});

// Skills data
const skills=[
  {name:'HTML5',     icon:'&lt;/&gt;', type:'frontend', level:95, cat:'Frontend',  color:'#e44d26'},
  {name:'CSS3',      icon:'{ }',       type:'frontend', level:90, cat:'Frontend',  color:'#264de4'},
  {name:'JavaScript',icon:'JS',        type:'frontend', level:88, cat:'Frontend',  color:'#f0db4f'},
  {name:'Bootstrap', icon:'B',         type:'frontend', level:92, cat:'Frontend',  color:'#7952b3'},
  {name:'jQuery',    icon:'$( )',      type:'frontend', level:85, cat:'Frontend',  color:'#0769ad'},
  {name:'C#',        icon:'C#',        type:'backend',  level:87, cat:'Backend',   color:'#9b4f96'},
  {name:'C',         icon:'C',         type:'backend',  level:75, cat:'Backend',   color:'#a8b9cc'},
  {name:'Python',    icon:'Py',        type:'backend',  level:82, cat:'Backend',   color:'#3572A5'},
  {name:'PHP',       icon:'PHP',       type:'backend',  level:84, cat:'Backend',   color:'#777bb4'},
  {name:'MySQL',     icon:'DB',        type:'database', level:88, cat:'Database',  color:'#00758f'},
  {name:'SQL Server',icon:'SQL',       type:'database', level:83, cat:'Database',  color:'#cc2927'},
];

function renderSkills(filter){
  const grid=document.getElementById('skills-grid');
  grid.innerHTML='';
  const list=filter==='all'?skills:skills.filter(s=>s.type===filter);
  list.forEach((s,i)=>{
    const c=document.createElement('div');c.className='skill-card';
    c.style.setProperty('--card-color',s.color);
    c.style.setProperty('--level',s.level+'%');
    c.style.transitionDelay=(i*.05)+'s';
    c.innerHTML=`<div class="skill-icon">${s.icon}</div><div><div class="skill-name">${s.name}</div><div class="skill-type">${s.cat}</div></div><div class="skill-bar-wrap"><div class="skill-bar"></div></div><div class="skill-level-txt">${s.level}%</div>`;
    grid.appendChild(c);
    setTimeout(()=>c.classList.add('animate'),80+i*55);
  });
}
renderSkills('all');
document.querySelectorAll('.skill-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.skill-tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    renderSkills(tab.dataset.filter);
  });
});

// Reveal
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:.1});
document.querySelectorAll('.reveal').forEach(r=>obs.observe(r));

// Counters
const cObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('[data-target]').forEach(el=>{
        const t=+el.dataset.target;let n=0;
        const step=()=>{n+=Math.ceil(t/35);if(n>=t){el.textContent=t+'+';return;}el.textContent=n;requestAnimationFrame(step);};
        requestAnimationFrame(step);
      });
      cObs.unobserve(e.target);
    }
  });
},{threshold:.5});
const sr=document.querySelector('.stats-row');if(sr)cObs.observe(sr);

// Parallax
window.addEventListener('scroll',()=>{
  const hn=document.querySelector('.hero-name');
  if(hn)hn.style.transform=`translateY(${window.scrollY*.12}px)`;
});

// AI Chat
const CONTEXT=`You are an AI assistant for a Full Stack Developer's portfolio. Here's their profile:

TECHNICAL SKILLS (all 11):
Frontend: HTML5, CSS3, JavaScript (ES6+), Bootstrap 4/5, jQuery
Backend: C# (ASP.NET MVC/.NET Core), C (systems programming), Python (Flask/Django), PHP
Databases: MySQL, Microsoft SQL Server (T-SQL, stored procedures, queries)

PROJECTS:
- Hospital Management System: C#, ASP.NET, SQL Server, Bootstrap — patient records, appointments, billing
- Inventory & POS System: PHP, MySQL, jQuery, Bootstrap — stock management, sales tracking
- REST API with Python Flask: Python, MySQL — RESTful endpoints, JSON responses
- Analytics Dashboard: HTML/CSS, JS, jQuery, Bootstrap — charts, data visualization

EXPERIENCE: 4+ years, 30+ projects, 15+ clients
AVAILABILITY: Open to freelance, contract, and full-time roles

Be concise (2–3 sentences), enthusiastic, and highlight specific skills relevant to questions. For hiring inquiries, direct them to use the email link.`;

let history=[],busy=false;

async function callClaude(msg){
  const msgs=[...history.map(m=>({role:m.role,content:m.content})),{role:'user',content:msg}];
  const r=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:CONTEXT,messages:msgs})
  });
  const d=await r.json();
  return d.content?.[0]?.text||"Connection hiccup — try again!";
}

function addMsg(role,text){
  const wrap=document.getElementById('chat-messages');
  const d=document.createElement('div');
  d.className='message'+(role==='user'?' user':'');
  d.innerHTML=`<div class="msg-avatar ${role==='user'?'usr':'ai'}">${role==='user'?'YOU':'AI'}</div><div class="msg-bubble">${text}</div>`;
  wrap.appendChild(d);wrap.scrollTop=wrap.scrollHeight;
}

function showTyping(){
  const wrap=document.getElementById('chat-messages');
  const d=document.createElement('div');d.className='message';d.id='typing';
  d.innerHTML=`<div class="msg-avatar ai">AI</div><div class="msg-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>`;
  wrap.appendChild(d);wrap.scrollTop=wrap.scrollHeight;
}

async function sendMessage(){
  if(busy)return;
  const inp=document.getElementById('chat-input');
  const txt=inp.value.trim();if(!txt)return;
  inp.value='';busy=true;
  document.getElementById('chat-send').disabled=true;
  document.getElementById('quick-qs').style.display='none';
  addMsg('user',txt);showTyping();
  try{
    const reply=await callClaude(txt);
    document.getElementById('typing')?.remove();
    addMsg('assistant',reply);
    history.push({role:'user',content:txt},{role:'assistant',content:reply});
  }catch(e){
    document.getElementById('typing')?.remove();
    addMsg('assistant','Connection issue — please try again!');
  }
  busy=false;document.getElementById('chat-send').disabled=false;
}

function sendQuick(btn){document.getElementById('chat-input').value=btn.textContent;sendMessage();}
document.getElementById('chat-input').addEventListener('keydown',e=>{if(e.key==='Enter')sendMessage();});
</script>
</body>
</html>
